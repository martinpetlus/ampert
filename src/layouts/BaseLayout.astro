---
import "../styles/global.css";
import { getRelativeLocaleUrl } from "astro:i18n";
import LanguageSwitcher from "../components/LanguageSwitcher.astro";
import { defaultLang, type Lang, useTranslations } from "../i18n/ui";

interface Props {
  title?: string;
}

const lang = (Astro.currentLocale ?? defaultLang) as Lang;
const t = useTranslations(lang);
const { title = t("site.title") } = Astro.props;
const base = import.meta.env.BASE_URL;
const homeHref = getRelativeLocaleUrl(lang, "");
const contactHref = getRelativeLocaleUrl(
  lang,
  lang === "sk" ? "kontakt" : "contact",
);
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <link
      rel="icon"
      type="image/svg+xml"
      href={`${base.replace(/\/$/, "")}/favicon.svg`}
    />
    <link
      rel="icon"
      type="image/png"
      href={`${base.replace(/\/$/, "")}/favicon.png`}
    />
    <link
      rel="apple-touch-icon"
      href={`${base.replace(/\/$/, "")}/favicon.png`}
    />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
  </head>
  <body class="min-h-screen bg-slate-50 text-slate-900">
    <header
      class="flex items-center justify-between border-b border-slate-200 px-6 py-4"
    >
      <div class="flex items-center gap-6">
        <a href={homeHref} class="flex items-center gap-2 font-semibold">
          <img
            src={`${base.replace(/\/$/, "")}/logo.svg`}
            alt=""
            width="32"
            height="32"
            class="h-8 w-8"
          />
          <span class="text-lg">{t("site.title")}</span>
        </a>
        <nav class="flex items-center gap-4 text-sm">
          <a href={homeHref} class="hover:underline">{t("nav.home")}</a>
          <a href={contactHref} class="hover:underline">{t("nav.contact")}</a>
        </nav>
      </div>
      <LanguageSwitcher />
    </header>
    <main class="mx-auto max-w-3xl px-6 py-12">
      <slot />
    </main>
  </body>
</html>
